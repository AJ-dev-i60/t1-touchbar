# Optional udev rule for t1-touchbar.
# Grants the 'video' group access to the iBridge USB device and the touch input
# device, so non-root code can open them. NOTE: the driver still needs root to
# unload/reload the kernel apple_touchbar/apple_ibridge modules during open/close
# (pass manage_modules=False and pre-unload them yourself to run fully unprivileged).
#
# Install:  sudo cp packaging/99-t1touchbar.rules /etc/udev/rules.d/
#           sudo udevadm control --reload && sudo udevadm trigger

SUBSYSTEM=="usb", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="8600", MODE="0660", GROUP="video"
SUBSYSTEM=="input", ATTRS{name}=="Apple Inc. iBridge Touchpad", MODE="0660", GROUP="video"
